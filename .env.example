POSTGRES_DB=mab_task_allocator
POSTGRES_USER=mab_user
POSTGRES_PASSWORD=mab_password
DATABASE_URL=postgresql://mab_user:mab_password@localhost:5432/mab_task_allocator
DATABASE_POOL_SIZE=10
DATABASE_SSL=false
ATTACHMENTS_PATH=apps/api/data/attachments
API_UPSTREAM=http://localhost:4000
# Optional: enables the AI assistant for every authenticated user.
# Create a free Gemini API key and set the same variable in Railway.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
